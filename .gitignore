# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/
testbin/*

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Output of gorelease
dist

# Ignore output by test
/**/_test

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
.idea
*.swp
*.swo
*~
.vscode

# SDD state files
.sdd-state.json

# SDD prompts
docs/prompts/

# SDD development specs
docs/development/

# Agent dirs
.cursor
.claude

# Provider runtime workspace artifacts
.complytime/

megalinter-reports/

# Ignore generated credentials from google-github-actions/auth
# See: https://github.com/google-github-actions/auth
gha-creds-*.json

# Speckit — managed by specify init (recreate with: specify init --ai opencode)
.specify/extensions.yml
.specify/extensions/
.specify/init-options.json
.specify/integration.json
.specify/integrations/
.specify/scripts
.specify/templates
.specify/workflows/
.opencode/commands/speckit.*.md
.opencode/commands/opsx-*.md
.opencode/skills/speckit-workflow/
.opencode/skills/openspec-*/

# Unbound Force convention packs not applicable to this repository.
.opencode/uf/packs/typescript.md
.opencode/uf/packs/typescript-custom.md

# Unbound Force — managed by uf init
# Runtime data under .uf/ (databases, caches, locks, logs)
.uf/workflows/
.uf/artifacts/
.uf/dewey/graph.db
.uf/dewey/graph.db-shm
.uf/dewey/graph.db-wal
.uf/dewey/*.lock
.uf/dewey/cache/
.uf/dewey/dewey.log
.uf/replicator/*.db
.uf/replicator/*.db-shm
.uf/replicator/*.db-wal
.uf/replicator/*.lock
.uf/replicator/*.log
.uf/muti-mind/artifacts/
.uf/mx-f/data/
# Legacy tool directories (renamed to .uf/ in Spec 025)
.dewey/
.hive/
.unbound-force/
.muti-mind/
.mx-f/

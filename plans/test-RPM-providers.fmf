summary: Validate complytime-providers RPM sub-packages deliver provider binaries

discover:
    how: shell

execute:
    script:
      - test -x /usr/libexec/complytime/providers/complyctl-provider-openscap
      - test -x /usr/libexec/complytime/providers/complyctl-provider-ampel
      - /usr/libexec/complytime/providers/complyctl-provider-openscap --help
      - /usr/libexec/complytime/providers/complyctl-provider-ampel --help
      - test -x /usr/libexec/complytime/providers/complyctl-provider-opa
      - /usr/libexec/complytime/providers/complyctl-provider-opa --help
